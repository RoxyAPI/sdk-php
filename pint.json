{
    "preset": "symfony",
    "exclude": [
        "src/Generated",
        "tests/Generated",
        "vendor",
        "node_modules"
    ],
    "rules": {
        "concat_space": {
            "spacing": "one"
        },
        "declare_strict_types": true,
        "phpdoc_align": {
            "align": "left"
        },
        "single_quote": true
    }
}
